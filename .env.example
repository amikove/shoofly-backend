PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=change_this_to_a_very_long_random_string_in_production
JWT_EXPIRES_IN=7d

# PostgreSQL (Render/Railway fournit DATABASE_URL automatiquement)
DATABASE_URL=postgresql://user:password@localhost:5432/shoofly

# CORS — URL de ton front
FRONTEND_URL=http://localhost:5173

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
